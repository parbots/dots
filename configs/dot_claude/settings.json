      "Bash(npx tailwindcss init -p)",
      "Bash(npx prettier:*)",
      "Bash(npx eslint:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(gh api:*)",
      "Bash(gh repo:*)",
      "Bash(gh run:*)",
      "Bash(gh auth:*)",
      "Bash(gh status:*)",
      "Bash(curl:*)",
      "Bash(curl -s \"http://localhost:3000/mp/helpdesk/webhook?validationToken=test123\")",
      "Bash(lsof:*)",
      "Bash(ps:*)",
      "Bash(pkill:*)",
      "Bash(kill:*)",
      "Bash(env:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(which:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(cargo test:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo check:*)",
      "Bash(cargo build:*)",
      "Bash(pnpm quality:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm mp-explore:*)",
      "mcp__plugin_vercel_vercel__get_runtime_logs",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__plugin_context7_context7__resolve-library-id"
    ],
    "defaultMode": "default"
  },
  "skipAutoPermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "spinnerTipsEnabled": true,
  "statusLine": {
    "command": "/Users/parkerb/.claude/statusline-bin",
    "type": "command"
  },
  "theme": "auto",
  "tui": "fullscreen"
}